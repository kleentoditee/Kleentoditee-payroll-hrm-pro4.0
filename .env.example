# Copy to .env in this folder (repo root). Used by API, Prisma (via packages/db scripts), and seed.

# Local dev (no Docker): path is relative to packages/db/prisma/ (where schema.prisma lives).
DATABASE_URL="file:./dev.db"

# Optional: PostgreSQL when Docker is running (`docker compose up -d` from repo root).
# DATABASE_URL="postgresql://kleentoditee:kleentoditee@localhost:5432/kleentoditee?schema=public"

# Min ~32 chars in production. Dev default is fine for localhost only.
JWT_SECRET="dev-only-change-me-use-openssl-rand-hex-32-in-real-deploy"

# Last resort on localhost only: passwordless "emergency" sign-in for the first user in the DB (see login page).
# Never enable in production. Remove before deploy.
# ALLOW_DEV_EMERGENCY_LOGIN=1

# Optional seed overrides (defaults shown in seed.ts)
# SEED_ADMIN_EMAIL=admin@kleentoditee.local
# SEED_ADMIN_PASSWORD=ChangeMe!Dev123
# SEED_ADMIN_NAME=Platform Admin

# Admin web → API (browser). For `next dev`, leave this UNSET so the admin uses a same-origin proxy
# to :8787 (avoids CORS / "Cannot talk to the API"). Set only for production or direct-URL debugging.
# NEXT_PUBLIC_API_URL=http://localhost:8787
